import os
import time
import sys

devices = [
    "Smart Light A1", "Projector B2", "Thermostat C3", "Security Camera D4",
    "Smart Lock E5", "Smoke Detector F6", "Door Sensor G7", "Smart Speaker H8",
    "Air Purifier I9", "Water Leak Sensor J10"
]

rented_status = [False] * len(devices)

def clear_screen():
    """Clears the console screen."""
    os.system('cls' if os.name == 'nt' else 'clear')

def display_menu():
    """Displays the main menu options."""
    print("\n--- Smart Home Device Manager ---")
    print("1. Add New Device")
    print("2. Update Device Status")
    print("3. View Available Devices")
    print("4. Search for a Device")
    print("5. Exit")
    print("--------------------------------")

def add_device():
    """Allows the user to add a new device."""
    clear_screen()
    device_name = input("Enter the name of the new device: ").strip()

    if device_name in devices:
        print("Device already exists.")
    else:
        devices.append(device_name)
        rented_status.append(False)
        print(f"'{device_name}' added successfully.")

    time.sleep(2)

def update_device_status():
    """Allows the user to update a device status."""
    clear_screen()
    device_name = input("Enter the name of the device you want to update: ").strip()

    if device_name in devices:
        index = devices.index(device_name)

        if not rented_status[index]:
            rented_status[index] = True
            print(f"Status of '{device_name}' updated to in use.")
        else:
            rented_status[index] = False
            print(f"Status of '{device_name}' updated to available.")
    else:
        print("Device not found.")

    time.sleep(2)

def view_available_devices():
    """Displays the available devices for use."""
    clear_screen()
    print("\nAvailable Devices:")
    available = False

    for i in range(len(devices)):
        if not rented_status[i]:
            print(f"- {devices[i]}")
            available = True

    if not available:
        print("No devices available.")

    time.sleep(2)

def search_device():
    """Searches for a particular device."""
    clear_screen()
    device_name = input("Enter the name of the device you want to search: ").strip()

    if device_name in devices:
        index = devices.index(device_name)
        if rented_status[index]:
            print(f"Name: {devices[index]}, Status: in use")
        else:
            print(f"Name: {devices[index]}, Status: available")
    else:
        print("Device not found.")

    time.sleep(2)

def exit_program():
    """Exits the program gracefully."""
    print("Exiting the system. Have a great day!")
    time.sleep(2)
    sys.exit()

def main():
    """Main function to run the smart home device manager."""
    while True:
        clear_screen()
        display_menu()
        choice = input("Enter your choice (1-5): ")

        if choice == '1':
            add_device()
        elif choice == '2':
            update_device_status()
        elif choice == '3':
            view_available_devices()
        elif choice == '4':
            search_device()
        elif choice == '5':
            exit_program()
        else:
            print("Invalid choice. Please select a valid option.")
            time.sleep(2)

if __name__ == "__main__":
    main()
